{
  "name": "auto-prestige",
  "version": "0.1.0",
  "private": true,
  "description": "Auto Prestige - Revista Digital Automotiva de Angola. A principal fonte de notícias, análises e tendências do mercado automobilístico angolano.",
  "author": "Auto Prestige Angola",
  "homepage": "https://autoprestige.ao",
  "repository": {
    "type": "git",
    "url": "https://github.com/autoprestige-angola/revista-digital"
  },
  "keywords": [
    "angola",
    "automóveis",
    "carros",
    "revista digital",
    "mercado automobilístico",
    "luanda",
    "kwanza",
    "concessionárias angola"
  ],
  "license": "MIT",
  "scripts": {
    "dev": "next dev --turbopack -p 3001",
    "build": "next build --turbopack",
    "start": "next start -p 3001",
    "lint": "eslint",
    "db:migrate": "node scripts/db/migrate.js",
    "test": "jest",
    "test:unit": "jest --testPathPatterns=tests/unit",
    "test:components": "jest --testPathPatterns=src/components/__tests__",
    "test:hooks": "jest --testPathPatterns=src/hooks/__tests__",
    "test:lib": "jest --testPathPatterns=src/lib/__tests__",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:unit && npm run test:e2e",
    "test:ci": "npm run lint && npm run test:coverage && npm run test:e2e && npm run build",
    "playwright:install": "playwright install",
    "playwright:install-deps": "playwright install-deps"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.544.0",
    "next": "15.5.4",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.55.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.15.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
